---
import { Code } from "astro:components"
import { getCollection, render } from "astro:content"
import ArrowIcon from "@/assets/arrow.svg"
import BlogPostActions from "@/components/BlogPostActions.astro"
import MainLayout from "@/layouts/MainLayout.astro"
import { readBlogMarkdownContent } from "@/lib/blog-markdown"
import {
  getBlogPostAlternateHref,
  getBlogPostLanguageLinks,
  getBlogPostTransitionName,
  type BlogPost,
} from "@/lib/blog"
import { getAlternateBlogPosts, getLocaleLanguageTag, getLocalizedPath } from "@/lib/i18n"
import { formatBlogDate, toIsoDateTime } from "@/lib/date-time"
import { buildBlogPostGraph } from "@/lib/seo"
import { getCategoryItemsByTranslationKey } from "@/lib/taxonomy"

interface Props {
  post: BlogPost
  posts: BlogPost[]
}

const { post, posts } = Astro.props
const { Content } = await render(post)
const canonical = new URL(getBlogPostAlternateHref(post), Astro.site).toString()
const ogImage = new URL(`${getBlogPostAlternateHref(post)}/og.png`, Astro.site).toString()
const alternatePosts = getAlternateBlogPosts(posts, post)
const defaultAlternatePost = alternatePosts.find((entry) => entry.data.locale === "en") ?? post
const alternates = {
  defaultLocale: "en",
  entries: [
    ...alternatePosts.map((entry) => ({
      href: new URL(getBlogPostAlternateHref(entry), Astro.site).toString(),
      hreflang: getLocaleLanguageTag(entry.data.locale),
    })),
    {
      href: new URL(getBlogPostAlternateHref(defaultAlternatePost), Astro.site).toString(),
      hreflang: "x-default",
    },
  ],
}
const labels = {
  en: {
    categories: "Post categories",
    backToBlog: "Blog",
    content: "Article content",
    published: "Published",
    updated: "Updated",
  },
  es: {
    categories: "Categorías del artículo",
    backToBlog: "Blog",
    content: "Contenido del artículo",
    published: "Publicado",
    updated: "Actualizado",
  },
}
const blogCategoriesEntries = await getCollection("blogCategories")
const blogCategoriesEntry = blogCategoriesEntries.find((entry) => entry.data.locale === post.data.locale)

if (!blogCategoriesEntry) {
  throw new Error(`Missing blogCategories for locale: ${post.data.locale}`)
}

const taxonomyItems = getCategoryItemsByTranslationKey(blogCategoriesEntry, post.data.categories).map(
  (category) => category.name,
)
const blogHref = getLocalizedPath(post.data.locale, "blog")
const markdown = await readBlogMarkdownContent(post.id)
const publishedDate = post.data.publishDate
const updatedDate = post.data.updatedDate
const lastModifiedDate = updatedDate ?? publishedDate
const seoDescription = post.data.seo.description
const graph = buildBlogPostGraph({
  description: seoDescription,
  image: ogImage,
  lang: post.data.locale,
  publishedDate,
  title: post.data.title,
  ...(updatedDate ? { updatedDate } : {}),
  url: canonical,
})
---

<MainLayout
  alternates={alternates}
  canonical={canonical}
  description={seoDescription}
  graph={graph}
  keywords={post.data.seo.keywords}
  lang={post.data.locale}
  languageLinks={getBlogPostLanguageLinks(posts, post)}
  ogImage={ogImage}
  title={post.data.title}
  titleTemplate="%s - Blog"
>
  <main
    class="prose prose-neutral prose-sm lg:prose-base dark:prose-invert prose-a:wrap-break-word prose-code:wrap-break-word prose-pre:max-w-full prose-pre:overflow-x-auto prose-table:block prose-table:max-w-full prose-table:overflow-x-auto prose-headings:text-pretty w-full max-w-full min-w-0 [&_.expressive-code]:max-w-full [&_.expressive-code]:overflow-x-auto [&_figure]:max-w-full"
  >
    <article>
      <header>
        <div class="not-prose mb-6 flex flex-wrap items-center justify-between gap-3">
          <a
            class="text-muted-foreground hover:text-foreground focus-visible:border-ring focus-visible:ring-ring/50 inline-flex h-8 w-fit items-center gap-1.5 text-sm transition-colors outline-none focus-visible:ring-3 [&_svg]:size-4"
            href={blogHref}
          >
            <ArrowIcon aria-hidden="true" class="-rotate-90" />
            <span>{labels[post.data.locale].backToBlog}</span>
          </a>

          <BlogPostActions
            locale={post.data.locale}
            markdown={markdown}
            title={post.data.title}
            url={canonical}
          />
        </div>

        <h1 style={`view-transition-name: ${getBlogPostTransitionName(post, "title")}`}>
          {post.data.title}
        </h1>

        <p style={`view-transition-name: ${getBlogPostTransitionName(post, "description")}`}>
          {post.data.description}
        </p>

        <div class="not-prose text-muted-foreground flex flex-wrap items-center gap-x-1 gap-y-2 text-sm">
          <time datetime={toIsoDateTime(publishedDate)}>
            {labels[post.data.locale].published}
            {" "}
            {formatBlogDate(publishedDate, post.data.locale)}
          </time>
          {
            updatedDate && (
              <>
                <span aria-hidden="true" class="text-muted-foreground text-xs">
                  /
                </span>
                <time datetime={toIsoDateTime(lastModifiedDate)}>
                  {labels[post.data.locale].updated} {formatBlogDate(lastModifiedDate, post.data.locale)}
                </time>
              </>
            )
          }
        </div>

        {
          taxonomyItems.length > 0 && (
            <ul
              aria-label={labels[post.data.locale].categories}
              class="not-prose my-6 flex list-none flex-wrap gap-2 ps-0"
            >
              {taxonomyItems.map((category) => (
                <li class="text-muted-foreground retina:border-[0.5px] inline-flex items-center rounded-none border bg-zinc-50 px-1.5 py-0.5 font-mono text-xs dark:bg-zinc-900">
                  {category}
                </li>
              ))}
            </ul>
          )
        }
      </header>

      <section aria-label={labels[post.data.locale].content}>
        <Content components={{ pre: Code }} />
      </section>
    </article>
  </main>
</MainLayout>

<style is:global>
  .expressive-code .copy button {
    border-radius: 0 !important;
  }

  @media (width <= 768px) {
    .expressive-code .copy button {
      width: 1.7rem !important;
      height: 1.7rem !important;
    }
  }
</style>
