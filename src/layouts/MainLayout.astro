---
import Seo from "@jdevalk/astro-seo-graph/Seo.astro"
import { buildLayoutSeoProps, type LayoutSeoProps } from "@/lib/seo"
import "@/styles/global.css"
import "@fontsource-variable/geist/wght.css"

interface Props extends LayoutSeoProps {
  lang?: string
}

const { lang = "en", ...seoProps } = Astro.props
const seo = buildLayoutSeoProps(seoProps, Astro.url)
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width" name="viewport" />
    <meta content={Astro.generator} name="generator" />
    <Seo {...seo} />
  </head>
  <body class="font-sans">
    <slot />
  </body>
</html>
