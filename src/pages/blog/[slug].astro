---
import { getCollection, render } from "astro:content"
import MainLayout from "@/layouts/MainLayout.astro"
import { getAlternateBlogPosts, getBlogPostSlug } from "@/lib/i18n"

export async function getStaticPaths() {
  const posts = await getCollection("blog")

  return posts
    .filter((post) => post.data.locale === "en" && !post.data.draft)
    .map((post) => ({
      params: { slug: getBlogPostSlug(post) },
      props: { post, posts },
    }))
}

const { post, posts } = Astro.props
const { Content } = await render(post)
const alternates = {
  defaultLocale: "en",
  entries: getAlternateBlogPosts(posts, post).map((entry) => ({
    href: new URL(
      entry.data.locale === "en" ? `/blog/${getBlogPostSlug(entry)}` : `/es/blog/${getBlogPostSlug(entry)}`,
      Astro.site,
    ).toString(),
    hreflang: entry.data.locale,
  })),
}
---

<MainLayout
  alternates={alternates}
  description={post.data.seo?.description ?? post.data.description}
  lang="en"
  title={post.data.seo?.title ?? post.data.title}
>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <article>
      <h1 class="text-4xl font-semibold">{post.data.title}</h1>
      <p class="mt-3">{post.data.description}</p>
      <div class="mt-10">
        <Content />
      </div>
    </article>
  </main>
</MainLayout>
