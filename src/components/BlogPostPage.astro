---
import { Code } from "astro:components"
import { render } from "astro:content"
import MainLayout from "@/layouts/MainLayout.astro"
import {
  getBlogPostAlternateHref,
  getBlogPostLanguageLinks,
  getBlogPostTransitionName,
  type BlogPost,
} from "@/lib/blog"
import { getAlternateBlogPosts } from "@/lib/i18n"

interface Props {
  post: BlogPost
  posts: BlogPost[]
}

const { post, posts } = Astro.props
const { Content } = await render(post)
const alternates = {
  defaultLocale: "en",
  entries: getAlternateBlogPosts(posts, post).map((entry) => ({
    href: new URL(getBlogPostAlternateHref(entry), Astro.site).toString(),
    hreflang: entry.data.locale,
  })),
}
---

<MainLayout
  alternates={alternates}
  description={post.data.description}
  lang={post.data.locale}
  languageLinks={getBlogPostLanguageLinks(posts, post)}
  title={post.data.title}
  titleTemplate="%s - Blog"
>
  <main
    class="prose prose-neutral prose-sm lg:prose-base dark:prose-invert prose-code:bg-transparent mx-auto max-w-prose"
  >
    <article>
      <h1 transition:name={getBlogPostTransitionName(post, "title")}>
        {post.data.title}
      </h1>

      <p transition:name={getBlogPostTransitionName(post, "description")}>
        {post.data.description}
      </p>

      <div>
        <Content components={{ pre: Code }} />
      </div>
    </article>
  </main>
</MainLayout>
