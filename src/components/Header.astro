---
import Logo from "@/assets/logo.svg"
import {
  getDefaultLanguageLinks,
  getLocaleLabel,
  getLocalizedPath,
  type LanguageLink,
  type Locale,
} from "@/lib/i18n"

import Separator from "@/components/Separator.astro"
import ThemeSwitcher from "@/components/ThemeSwitcher.astro"

interface Props {
  languageLinks?: LanguageLink[] | undefined
  locale: Locale
  pathname: string
}

const { languageLinks, locale, pathname } = Astro.props
const links = languageLinks ?? getDefaultLanguageLinks()
const logoHref = getLocalizedPath(locale)
const blogHref = getLocalizedPath(locale, "blog")
const normalizedPathname = pathname.replace(/\/$/, "") || "/"
const isBlogActive = normalizedPathname === blogHref
const navLinkClass =
  "text-muted-foreground hover:text-foreground cursor-pointer data-active:text-foreground inline-flex h-8 items-center px-2 text-sm font-medium transition-colors"
---

<header class="flex items-center justify-between">
  {
    pathname === "/" || pathname === "/es" ? (
      <Logo aria-label="Rxtsel logo" class="cursor-pointer" height={30} width={29} />
    ) : (
      <a class="logo" href={logoHref}>
        <Logo aria-label="Rxtsel logo" height={30} width={29} />
      </a>
    )
  }

  <nav class="flex items-center">
    {
      isBlogActive ? (
        <span aria-current="page" class:list={navLinkClass} data-active data-hover-ghost-item>
          Blog
        </span>
      ) : (
        <a class:list={navLinkClass} data-hover-ghost-item href={blogHref}>
          Blog
        </a>
      )
    }

    <Separator />

    <div aria-label="Language selector" class="flex">
      {
        links.map((link) =>
          link.locale === locale ? (
            <span
              aria-current="true"
              aria-label={getLocaleLabel(link.locale)}
              class:list={navLinkClass}
              data-active
              data-hover-ghost-item
              lang={link.locale}
            >
              {link.locale.toUpperCase()}
            </span>
          ) : (
            <a
              aria-label={getLocaleLabel(link.locale)}
              class:list={navLinkClass}
              data-hover-ghost-item
              href={link.href}
              lang={link.locale}
            >
              {link.locale.toUpperCase()}
            </a>
          ),
        )
      }
    </div>

    <Separator class="mr-3" />

    <ThemeSwitcher />
  </nav>
</header>
