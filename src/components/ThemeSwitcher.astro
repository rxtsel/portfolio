---
import MonitorIcon from "@/assets/desktop-screen.svg"
import MoonIcon from "@/assets/moon.svg"
import SunIcon from "@/assets/soon.svg"
---

<button
  aria-label="System theme. Switch to light theme"
  class="bg-background ring-border text-muted-foreground/80 hover:text-foreground data-active:text-foreground hover:bg-accent inline-flex size-8 items-center justify-center ring-1 transition-colors ring-inset [&_svg]:size-4"
  data-theme-toggle
  onclick="haptic()"
  type="button"
>
  <MonitorIcon data-theme-icon="system" />
  <SunIcon data-theme-icon="light" hidden />
  <MoonIcon data-theme-icon="dark" hidden />
</button>
