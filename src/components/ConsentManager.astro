---
import { getIntegrations, matchesAllowedPath } from "@/lib/integrations"
import { PUBLIC_C15T_URL } from "astro:env/client"

const backendURL = PUBLIC_C15T_URL?.trim()
const integrations = await getIntegrations()
const googleAnalyticsMeasurementId = integrations?.googleAnalytics.enabled
  ? integrations.googleAnalytics.measurementId.trim()
  : ""
const googleAdsense = integrations?.googleAdsense
const googleAdsenseClientId =
  googleAdsense?.enabled && matchesAllowedPath(Astro.url.pathname, googleAdsense.allowedPathPattern)
    ? googleAdsense.clientId.trim()
    : ""
const locale = Astro.currentLocale ?? "en"
---

{
  backendURL && (
    <>
      <div id="c15t-consent-ui" />
      <div
        data-backend-url={backendURL}
        data-google-adsense-client-id={googleAdsenseClientId}
        data-google-analytics-measurement-id={googleAnalyticsMeasurementId}
        data-locale={locale}
        hidden
        id="consent-manager-config"
      />
    </>
  )
}

<script>
  import { startConsentManager } from "@/integrations/c15t/client"

  const config = document.getElementById("consent-manager-config")

  if (config instanceof HTMLElement) {
    startConsentManager({
      backendURL: config.dataset.backendUrl ?? "",
      googleAdsenseClientId: config.dataset.googleAdsenseClientId,
      googleAnalyticsMeasurementId: config.dataset.googleAnalyticsMeasurementId,
      locale: config.dataset.locale ?? "en",
    })
  }
</script>
