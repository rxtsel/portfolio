---
import { getCollection, getEntry, render } from "astro:content"
import BlogPostLink from "@/components/BlogPostLink.astro"
import MainLayout from "@/layouts/MainLayout.astro"
import { getSelectedPublishedPosts } from "@/lib/blog"
import { getDefaultLanguageLinks, type Locale } from "@/lib/i18n"

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const labels = {
  en: {
    experience: "Experience",
    latestPosts: "Latest posts",
    missingHome: "Missing English home content",
    present: "Present",
    projects: "Projects",
    stack: "Stack",
  },
  es: {
    experience: "Experiencia",
    latestPosts: "Últimos posts",
    missingHome: "Missing Spanish home content",
    present: "Actualidad",
    projects: "Proyectos",
    stack: "Stack",
  },
} satisfies Record<Locale, Record<string, string>>

const home = await getEntry("home", locale)

if (!home) {
  throw new Error(labels[locale].missingHome)
}

const { Content } = await render(home)
const posts = await getCollection("blog")
const latestPosts = getSelectedPublishedPosts(posts, home.data.latestPosts, locale)
---

<MainLayout
  alternatesPath=""
  description={home.data.seo?.description ?? home.data.description}
  lang={locale}
  languageLinks={getDefaultLanguageLinks()}
  title={home.data.seo?.title ?? home.data.title}
  titleTemplate="%s"
>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-semibold">{home.data.heroTitle}</h1>
    <p class="mt-4 text-lg">{home.data.intro}</p>

    {
      home.data.experience.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-semibold">{labels[locale].experience}</h2>
          <div class="mt-4 space-y-6">
            {home.data.experience.map((item) => (
              <article>
                <h3 class="font-medium">{item.role}</h3>
                <p>{item.company}</p>
                <p>
                  {item.startDate}
                  {item.endDate ? ` - ${item.endDate}` : ` - ${labels[locale].present}`}
                </p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      home.data.projects.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-semibold">{labels[locale].projects}</h2>
          <div class="mt-4 space-y-6">
            {home.data.projects.map((project) => (
              <article>
                <h3 class="font-medium">
                  {project.href ? <a href={project.href}>{project.name}</a> : project.name}
                </h3>
                <p>{project.description}</p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      latestPosts.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-semibold">{labels[locale].latestPosts}</h2>
          <ul class="mt-4 list-none space-y-6 p-0">
            {latestPosts.map((post) => (
              <li>
                <BlogPostLink headingLevel="h3" post={post} />
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <div class="mt-12">
      <Content />
    </div>

    {
      home.data.stack.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-semibold">{labels[locale].stack}</h2>
          <ul class="mt-4 flex list-none flex-wrap gap-2 p-0">
            {home.data.stack.map((item) => (
              <li>
                {item.href ? (
                  <a class="inline-flex rounded border px-3 py-1 text-sm" href={item.href}>
                    {item.tech}
                  </a>
                ) : (
                  <span class="inline-flex rounded border px-3 py-1 text-sm">{item.tech}</span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</MainLayout>
