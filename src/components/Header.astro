---
import Logo from "@/assets/logo.svg"
import {
  getDefaultLanguageLinks,
  getLocaleLanguageTag,
  getLocaleLabel,
  getLocalizedPath,
  type LanguageLink,
  type Locale,
} from "@/lib/i18n"

import Separator from "@/components/Separator.astro"
import ThemeSwitcher from "@/components/ThemeSwitcher.astro"

interface Props {
  languageLinks?: LanguageLink[] | undefined
  locale: Locale
  pathname: string
}

const { languageLinks, locale, pathname } = Astro.props
const links = languageLinks ?? getDefaultLanguageLinks()
const logoHref = getLocalizedPath(locale)
const blogHref = getLocalizedPath(locale, "blog")
const normalizedPathname = pathname.replace(/\/$/, "") || "/"
const isBlogActive = normalizedPathname === blogHref.replace(/\/$/, "")
const navLinkClass =
  "text-muted-foreground hover:text-foreground data-active:text-foreground inline-flex h-8 items-center px-1 text-sm font-medium transition-colors"
const languageLinkClass =
  "text-muted-foreground hover:text-foreground data-active:text-foreground inline-flex h-8 items-center text-sm font-medium transition-colors"
const labels = {
  en: {
    language: "Language selector",
    primary: "Primary",
  },
  es: {
    language: "Selector de idioma",
    primary: "Principal",
  },
} satisfies Record<Locale, Record<string, string>>
---

<header class="bg-background sticky top-0 z-50 flex items-center justify-between py-2" id="header">
  {
    pathname === "/" || pathname === "/es/" ? (
      <Logo aria-label="Rxtsel logo" height={30} width={29} />
    ) : (
      <a class="logo" href={logoHref}>
        <Logo aria-label="Rxtsel logo" height={30} width={29} />
      </a>
    )
  }

  <div class="flex items-center">
    <nav aria-label={labels[locale].primary} class="flex items-center">
      {
        isBlogActive ? (
          <span aria-current="page" class:list={navLinkClass} data-active data-hover-ghost-item>
            Blog
          </span>
        ) : (
          <a class:list={navLinkClass} data-hover-ghost-item href={blogHref}>
            Blog
          </a>
        )
      }
    </nav>

    <Separator />

    <nav aria-label={labels[locale].language} class="flex items-center gap-x-1 px-1">
      {
        links.map((link, index) => (
          <>
            {index > 0 && (
              <span aria-hidden="true" class="text-muted-foreground/40 text-sm">
                /
              </span>
            )}
            {link.locale === locale ? (
              <span
                aria-current="true"
                aria-label={getLocaleLabel(link.locale)}
                class:list={languageLinkClass}
                data-active
                lang={getLocaleLanguageTag(link.locale)}
              >
                {link.locale.toUpperCase()}
              </span>
            ) : (
              <a
                aria-label={getLocaleLabel(link.locale)}
                class:list={languageLinkClass}
                href={link.href}
                hreflang={getLocaleLanguageTag(link.locale)}
                lang={getLocaleLanguageTag(link.locale)}
              >
                {link.locale.toUpperCase()}
              </a>
            )}
          </>
        ))
      }
    </nav>

    <Separator class="mr-2" />

    <ThemeSwitcher />
  </div>
</header>

<style>
  #header {
    animation: blur linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  @keyframes blur {
    to {
      --tw-shadow: 0 1px var(--tw-shadow-color, rgb(0 0 0 / 0.05));
      box-shadow:
        var(--tw-inset-shadow), var(--tw-inset-ring-shadow), var(--tw-ring-offset-shadow),
        var(--tw-ring-shadow), var(--tw-shadow);
    }
  }
</style>
