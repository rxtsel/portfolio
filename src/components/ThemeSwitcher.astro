---
import MonitorIcon from "@/assets/desktop-screen.svg"
import MoonIcon from "@/assets/moon.svg"
import SunIcon from "@/assets/soon.svg"
---

<button
  aria-label="System theme. Switch to light theme"
  class="bg-background ring-border text-foreground hover:bg-accent inline-flex size-8 items-center justify-center ring-1 transition-colors ring-inset [&_svg]:size-4"
  data-theme-toggle
  onclick="haptic()"
  type="button"
>
  <MonitorIcon class="block" data-theme-icon="system" />
  <SunIcon class="hidden" data-theme-icon="light" />
  <MoonIcon class="hidden" data-theme-icon="dark" />
</button>
