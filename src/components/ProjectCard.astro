---
import GitHubIcon from "@/assets/logos/github.svg"
import type { ProjectTransitionPart } from "@/lib/projects"
import Tags from "./Tags.astro"
import FaviconResolver from "./FaviconResolver.astro"

type TaxonomyItem = {
  name: string
}

interface Props {
  customFavicon: string | undefined
  description: string
  headingLevel?: "h2" | "h3"
  href: string | undefined
  sourceUrl: string | undefined
  taxonomyItems: TaxonomyItem[]
  title: string
  transitionNames?: Partial<Record<ProjectTransitionPart, string>>
}

const {
  customFavicon,
  description,
  headingLevel = "h3",
  href,
  sourceUrl,
  taxonomyItems,
  title,
  transitionNames = {},
} = Astro.props
const Heading = headingLevel
const getTransitionStyle = (part: ProjectTransitionPart) =>
  transitionNames[part] ? `view-transition-name: ${transitionNames[part]}` : undefined
const tagsStyle = getTransitionStyle("tags")
const tagsProps = tagsStyle ? { style: tagsStyle } : {}
---

<article class="flex h-full flex-col gap-2 p-4" style={getTransitionStyle("card")}>
  <Heading class="flex items-center justify-between text-lg font-medium" style={getTransitionStyle("title")}>
    {
      href ? (
        <a
          class="link-underline item-center flex gap-2"
          href={`${href}?utm_source=rxtsel.dev&utm_medium=referral`}
          rel="noopener noreferrer"
          target="_blank"
        >
          <FaviconResolver customFavicon={customFavicon} href={href} />
          {title}
        </a>
      ) : customFavicon ? (
        <span class="item-center flex gap-2">
          <FaviconResolver customFavicon={customFavicon} href="" />
          {title}
        </span>
      ) : (
        title
      )
    }

    {
      sourceUrl ? (
        <a
          aria-label={`View ${title} on GitHub`}
          href={`${sourceUrl}?utm_source=rxtsel.dev`}
          rel="noopener noreferrer"
          style={getTransitionStyle("source")}
          target="_blank"
          title="View source on GitHub"
        >
          <GitHubIcon class="text-foreground size-4.5 shrink-0" />
        </a>
      ) : (
        <span style={getTransitionStyle("source")}>
          <GitHubIcon class="size-4.5 shrink-0 opacity-40" />
        </span>
      )
    }
  </Heading>

  <p class="text-muted-foreground flex-1" style={getTransitionStyle("description")}>{description}</p>

  <Tags {...tagsProps} tags={taxonomyItems} />
</article>
