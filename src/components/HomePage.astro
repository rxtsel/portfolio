---
import { getCollection, getEntry } from "astro:content"
import BlogPostLink from "@/components/BlogPostLink.astro"
import MainLayout from "@/layouts/MainLayout.astro"
import { getSelectedPublishedPosts } from "@/lib/blog"
import { getDefaultLanguageLinks, type Locale } from "@/lib/i18n"
import { getProjectTaxonomyItems, getStackItemsBySlug } from "@/lib/taxonomy"
import GitHubIcon from "@/assets/github.svg"

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const labels = {
  en: {
    experience: "Experience",
    latestPosts: "Latest posts",
    missingHome: "Missing English home content",
    present: "Present",
    projects: "Projects",
    stack: "Stack",
  },
  es: {
    experience: "Experiencia",
    latestPosts: "Últimos posts",
    missingHome: "Missing Spanish home content",
    present: "Actualidad",
    projects: "Proyectos",
    stack: "Stack",
  },
} satisfies Record<Locale, Record<string, string>>

const home = await getEntry("home", locale)

if (!home) {
  throw new Error(labels[locale].missingHome)
}

const posts = await getCollection("blog")
const latestPosts = getSelectedPublishedPosts(posts, home.data.latestPosts, locale)
const [stack] = await getCollection("stack")
const [tags] = await getCollection("tags")

if (!stack) {
  throw new Error("Missing stack content")
}

if (!tags) {
  throw new Error("Missing tags content")
}

const stackItems = getStackItemsBySlug(stack, home.data.stack)
const projects = home.data.projects.map((project) => ({
  ...project,
  taxonomyItems: getProjectTaxonomyItems({
    stackEntry: stack,
    stackSlugs: project.stack,
    tagSlugs: project.tags,
    tagsEntry: tags,
  }),
}))
---

<MainLayout
  alternatesPath=""
  description={home.data.seo?.description ?? home.data.intro}
  lang={locale}
  languageLinks={getDefaultLanguageLinks()}
  title={home.data.seo?.title ?? home.data.title}
  titleTemplate="%s"
>
  <main
    class="prose dark:prose-invert prose-neutral prose-sm lg:prose-base prose-p:text-muted-foreground prose-a:no-underline mx-auto max-w-prose"
  >
    <h1>{home.data.title}</h1>
    <p class="whitespace-pre-wrap">{home.data.intro}</p>

    {
      projects.length > 0 && (
        <section>
          <h2>{labels[locale].projects}</h2>
          <ul class="not-prose grid grid-cols-1 gap-0 sm:grid-cols-2 sm:gap-2">
            {projects.map((project) => (
              <li class="border odd:border-0 odd:border-x first-of-type:border-t sm:odd:border">
                <article class="flex h-full flex-col gap-2 p-4">
                  <h3 class="flex items-center justify-between text-lg font-medium">
                    {project.href ? (
                      <a class="link-underline" href={project.href} rel="noopener noreferrer" target="_blank">
                        {project.name}
                      </a>
                    ) : (
                      project.name
                    )}

                    {project.sourceUrl ? (
                      <a
                        aria-label={`View ${project.name} on GitHub`}
                        class="ghost"
                        href={project.sourceUrl}
                        rel="noopener noreferrer"
                        target="_blank"
                        title={`View source on GitHub`}
                      >
                        <GitHubIcon class="text-foreground size-4.5 shrink-0" />
                      </a>
                    ) : (
                      <GitHubIcon
                        aria-label={`No source code available for ${project.name}`}
                        class="size-4.5 shrink-0 opacity-40"
                      />
                    )}
                  </h3>

                  <p class="text-muted-foreground flex-1">{project.description}</p>

                  <ul class="flex flex-wrap gap-2">
                    {project.taxonomyItems.map((item) => (
                      <li class="text-muted-foreground retina:border-[0.5px] inline-flex items-center rounded-none border bg-zinc-50 px-1.5 py-0.5 font-mono text-xs dark:bg-zinc-900 [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-3.5">
                        {item.name}
                      </li>
                    ))}
                  </ul>
                </article>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      home.data.experience.length > 0 && (
        <section>
          <h2>{labels[locale].experience}</h2>
          <div>
            {home.data.experience.map((item) => (
              <article>
                <h3>{item.role}</h3>
                <p>{item.company}</p>
                <p>
                  {item.startDate}
                  {item.endDate ? ` - ${item.endDate}` : ` - ${labels[locale].present}`}
                </p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      latestPosts.length > 0 && (
        <section>
          <h2>{labels[locale].latestPosts}</h2>
          <ul>
            {latestPosts.map((post) => (
              <li>
                <BlogPostLink headingLevel="h3" post={post} />
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      stackItems.length > 0 && (
        <section>
          <h2>{labels[locale].stack}</h2>
          <ul>
            {stackItems.map((item) => (
              <li>{item.href ? <a href={item.href}>{item.name}</a> : <span>{item.name}</span>}</li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</MainLayout>
