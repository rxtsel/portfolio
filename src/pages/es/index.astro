---
import { getCollection, getEntry, render } from "astro:content"
import MainLayout from "@/layouts/MainLayout.astro"
import { getSelectedPublishedPosts } from "@/lib/blog"
import { getBlogPostPath } from "@/lib/i18n"

const home = await getEntry("home", "es")

if (!home) {
  throw new Error("Missing Spanish home content")
}

const { Content } = await render(home)
const posts = await getCollection("blog")
const latestPosts = getSelectedPublishedPosts(posts, home.data.latestPosts, "es")
---

<MainLayout
  alternatesPath=""
  description={home.data.seo?.description ?? home.data.description}
  lang="es"
  title={home.data.seo?.title ?? home.data.title}
  titleTemplate="%s"
>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-semibold">{home.data.heroTitle}</h1>
    <p class="mt-4 text-lg">{home.data.intro}</p>

    {
      home.data.experience.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-semibold">Experiencia</h2>
          <div class="mt-4 space-y-6">
            {home.data.experience.map((item) => (
              <article>
                <h3 class="font-medium">{item.role}</h3>
                <p>{item.company}</p>
                <p>
                  {item.startDate}
                  {item.endDate ? ` - ${item.endDate}` : " - Actualidad"}
                </p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      home.data.projects.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-semibold">Proyectos</h2>
          <div class="mt-4 space-y-6">
            {home.data.projects.map((project) => (
              <article>
                <h3 class="font-medium">
                  {project.href ? <a href={project.href}>{project.name}</a> : project.name}
                </h3>
                <p>{project.description}</p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      latestPosts.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-semibold">Últimos posts</h2>
          <div class="mt-4 space-y-6">
            {latestPosts.map((post) => (
              <article>
                <h3 class="font-medium">
                  <a href={getBlogPostPath(post)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <div class="mt-12">
      <Content />
    </div>

    {
      home.data.stack.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-semibold">Stack</h2>
          <ul class="mt-4 flex flex-wrap gap-2">
            {home.data.stack.map((item) => (
              <li>
                {item.href ? (
                  <a class="inline-flex rounded border px-3 py-1 text-sm" href={item.href}>
                    {item.tech}
                  </a>
                ) : (
                  <span class="inline-flex rounded border px-3 py-1 text-sm">{item.tech}</span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</MainLayout>
